	return ["(*^▽^*)", "(≧▽≦)", "o(*￣▽￣*)ブ", "(´▽`ʃ♡ƪ)", "٩(๑•̀ω•́๑)۶", "ヽ(✿ﾟ▽ﾟ)ノ", "(*´∀`)~♥", "(≧∀≦)", "(｡♥‿♥｡)", "ヾ(＾∇＾)"]

